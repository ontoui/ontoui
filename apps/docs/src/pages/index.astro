---
import '../styles/index.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OntoUI — Agent-first React components</title>
    <meta
      name="description"
      content="A React component library built for LLM agents. Tightly-scoped, composable, and easy to reason about."
    />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
  </head>
  <body>
    <!-- Navbar -->
    <header class="navbar">
      <a href="/" class="navbar__logo">
        <img src="/logo.svg" alt="OntoUI" class="navbar__logo-img" />
      </a>
      <nav class="navbar__links">
        <a
          href="https://github.com/ontoui/ontoui"
          class="navbar__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
          GitHub
        </a>
        <a href="/components/button/" class="navbar__link">Components</a>
      </nav>
    </header>

    <!-- Hero -->
    <main>
      <section class="hero">
        <div class="hero__icon" aria-hidden="true">
          <img src="/icon.svg" width="96" height="96" />
        </div>

        <h1 class="hero__headline">
          Built For<br />
          <span class="hero__accent">LLM Agents.</span>
        </h1>

        <p class="hero__subtitle">
          Tightly-scoped, composable React components with predictable props and minimal surface
          area — straightforward for agents to discover, use, and compose without ambiguity.
        </p>

        <div class="hero__actions">
          <a href="/components/button/" class="btn btn_type_primary">
            Browse Components
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
          <a href="/overview/getting-started/" class="btn btn_type_secondary">Getting Started</a>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <span class="footer__logo">OntoUI</span>
      <span class="footer__copy">MIT License</span>
    </footer>
  </body>
</html>
